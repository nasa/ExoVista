def get_data_cube(star, spots, lon_center=0., lat_center=0., lmid = 0.55, bandpass=0.125, bins=10):

    pix = star_map_ortho(star, spots, lon_center=lon_center, lat_center=lat_center, mapsize=180)
    npix = pix.shape[0]*pix.shape[1]
    
    spec_quiet = get_single_spectrum(star['Teff'],star['logg'])
    spec_gran = get_single_spectrum(star['Teff']-star['GranDeltaT'],star['logg'])
    spec_penumbra = get_single_spectrum(star['TeffPenumbra'],star['logg'])
    spec_umbra = get_single_spectrum(star['TeffUmbra'],star['logg'])
    
    spec_quiet = spec_quiet*(1-star['GranCoverage']) + spec_gran*star['GranCoverage']
    
    lmin = np.log(lmid * (1-bandpass/2))
    lmax = np.log(lmid * (1+bandpass/2))
    #binedges = np.exp(np.linspace(lmin,lmax,bins+1))
    binedges = np.linspace(np.exp(lmin),np.exp(lmax),bins+1)
    bincenter = (binedges[1:bins+1]+binedges[0:bins])/2

    binned_quiet = np.zeros(bins)
    binned_penumbra = np.zeros(bins)
    binned_umbra = np.zeros(bins)
    
    for i in range(0,bins):
        imin = np.where(lam >= binedges[i])[0][0]
        imax = np.where(lam > binedges[i+1])[0][0]
        print(i,imin,imax)
        binned_quiet[i] = np.average(spec_quiet[imin:imax])
        binned_penumbra[i] = np.average(spec_penumbra[imin:imax])
        binned_umbra[i] = np.average(spec_umbra[imin:imax])
        
    cube = np.zeros((pix.shape[0],pix.shape[1],bins))
    
