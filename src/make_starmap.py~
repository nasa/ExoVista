def ld_single(r, rstar, u1=0., u2=0.):
    mu = np.sqrt(1 - r**2)
    mu2 = max(1-mu,0)
    mask = 1 - (u1+1) * mu2 - u2 * mu2**2
    mask = max(mask/mu,0)
    if np.isnan(mask): mask = np.nan_to_num(mask)
    return mask

def limb_darkening(mapsize, u1=0., u2=0.):
    mu = np.zeros((mapsize,mapsize))
    mask = np.zeros((mapsize,mapsize))
    start = time.time()
    print('Start of loop: ',time.time()-start)
    for i in range(0,mapsize):
        for j in range(0,mapsize):
            mu[i,j] = np.sqrt((mapsize/2)**2 - (i-mapsize/2)**2 - (j-mapsize/2)**2) / (mapsize/2)
    print('End of loop: ',time.time()-start)
    mu2 = np.maximum(1-mu,0)
    mask = 1 - (u1+1) * mu2 - u2 * mu2**2
    mask = np.maximum(mask/mu,0)
    mask = np.nan_to_num(mask)
    print('End of routine: ',time.time()-start)
    return mask



def spot_areas(star, spots, star_area, lon_center=0, lat_center=0, planet=0, index=0):
    
    a = lat_center - np.pi/2
    if 'PA' in star.head(): b = star['PA'] * np.pi/180
    else: b = 0. # was np.pi/3
    c = -lon_center
    
    cosa = np.cos(a)
    sina = np.sin(a)
    cosb = np.cos(b) # y-axis pointed into the screen
    sinb = np.sin(b)
    cosc = np.cos(c)
    sinc = np.sin(c)

    Rz_matrix = np.matrix([[cosc, -sinc, 0],
                           [sinc,  cosc, 0],
                           [   0,     0, 1]])
    
    Rx_matrix = np.matrix([[1,    0,     0],
                           [0, cosa, -sina],
                           [0, sina,  cosa]])
        
    Ry_matrix = np.matrix([[cosb, -sinb, 0],
                           [sinb,  cosb, 0],
                           [   0,     0, 1]])
    
    rot_matrix = np.matmul(Ry_matrix,np.matmul(Rx_matrix,Rz_matrix))

    rstar = star['rstar']*R_sun

    p_area = np.array(spots['CurrentArea'].values)
    area_rat = np.array(spots['AreaRatio'].values)
    lat = np.array(spots['Latitude'].values * np.pi/180)
    lon = np.array(spots['Longitude'].values * np.pi/180)

    u_area = p_area/area_rat
    pr_spot = np.sqrt(p_area/np.pi)
    ur_spot = np.sqrt(u_area/np.pi)
    rho_pen = np.sqrt(rstar**2 - pr_spot**2)/rstar
    rho_umb = np.sqrt(rstar**2 - ur_spot**2)/rstar
    theta = lon + np.pi/2
    phi = lat - np.pi/2

    xp = rho_pen * np.cos(theta) * np.sin(phi)
    yp = rho_pen * np.sin(theta) * np.sin(phi)
    zp = rho_pen * np.cos(phi)
    
    xu = rho_umb * np.cos(theta) * np.sin(phi)
    yu = rho_umb * np.sin(theta) * np.sin(phi)
    zu = rho_umb * np.cos(phi)

    s_proj = star_area
    p_proj = 0
    u_proj = 0
    
    for i in range(0,len(spots)):        
        vec_p = np.array([xp[i],yp[i],zp[i]])
        new_p = np.ravel(rot_matrix.dot(vec_p))
        
        vec_u = np.array([xu[i],yu[i],zu[i]])
        new_u = np.ravel(rot_matrix.dot(vec_u))
        
        if new_p[2] < 0 or new_u[2] < 0: continue
        
        #new_phi_p = np.arccos(new_p[2]/rho_pen[i])              # specifies angular tilt of spot in radians
        #new_phi_u = np.arccos(new_u[2]/rho_umb[i])
        
        rp = np.sqrt(new_p[0]**2 + new_p[1]**2)
        #width_p = pr_spot[i]/rstar*np.cos(new_phi_p)
        width_p = pr_spot[i]/rstar * new_p[2]/rho_pen[i]
        height_p = pr_spot[i]/rstar
        
        ru = np.sqrt(new_u[0]**2 + new_u[1]**2)
        #width_u = ur_spot[i]/rstar*np.cos(new_phi_u)
        width_u = ur_spot[i]/rstar * new_u[2]/rho_umb[i]
        height_u = ur_spot[i]/rstar
        
        ldp = ld_single(rp, rstar/R_sun, u1=0.0473, u2=0.0841)
        ldu = ld_single(ru, rstar/R_sun, u1=0.0473, u2=0.0841)

        s_proj -= width_p * height_p * ldp
        p_proj += width_p * height_p * ldp
        u_proj += width_u * height_u * ldu
        
    return [s_proj,p_proj,u_proj]


